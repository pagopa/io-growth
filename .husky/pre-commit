STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# ESLint fix on staged ts/tsx files under ced-portal-fe
TS_FILES=$(echo "$STAGED_FILES" | grep -E '^apps/ced-portal-fe/.*\.(ts|tsx)$' || true)
if [ -n "$TS_FILES" ]; then
  echo "$TS_FILES" | xargs pnpm exec eslint --fix --no-error-on-unmatched-pattern
  echo "$TS_FILES" | xargs pnpm exec prettier --write
  echo "$TS_FILES" | xargs git add
fi

# Prettier fix on staged json/css/md files under ced-portal-fe
OTHER_FILES=$(echo "$STAGED_FILES" | grep -E '^apps/ced-portal-fe/.*\.(json|css|md)$' || true)
if [ -n "$OTHER_FILES" ]; then
  echo "$OTHER_FILES" | xargs pnpm exec prettier --write
  echo "$OTHER_FILES" | xargs git add
fi
