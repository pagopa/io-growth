{
  "dockerComposeFile": "docker-compose.yml",
  "service": "workspace",
  "workspaceFolder": "/workspaces/io-growth",
  "initializeCommand": "sh ./.devcontainer/scripts/export-devcontainer-ca.sh || echo Windows host requires WSL or a POSIX shell for certificate export",
  "features": {
    "ghcr.io/devcontainers-extra/features/pre-commit:2": {},
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/jlaundry/devcontainer-features/azure-functions-core-tools:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "latest",
      "tflint": "latest",
      "installTFsec": true,
      "installTerraformDocs": true
    },
    "ghcr.io/pagopa/devcontainer-features/trivy:1": {},
    "ghcr.io/pagopa/devcontainer-features/plantuml:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22",
      "installYarnUsingApt": false,
      "pnpmVersion": "none",
      "nvmInstallPath": "/opt/nvm"
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": true
    }
  },
  "postStartCommand": {
    "set-workspace-as-safe-dir": "git config --global --add safe.directory ${containerWorkspaceFolder}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "-vscjava.vscode-java-pack",
        "-ms-dotnettools.csharp",
        "-ms-azuretools.vscode-azureterraform",
        "ms-azuretools.vscode-azurefunctions",
        "ms-azuretools.vscode-azure-github-copilot",
        "ms-vscode.vscode-websearchforcopilot",
        "ms-azuretools.vscode-azureterraform",
        "github.vscode-github-actions",
        "github.vscode-pull-request-github",
        "arcanis.vscode-zipfs",
        "esbenp.prettier-vscode",
        "EditorConfig.EditorConfig",
        "bruno-api-client.bruno",
        "vitest.explorer",
        "redhat.vscode-yaml",
        "dbaeumer.vscode-eslint",
        "github.copilot"
      ]
    }
  }
}
