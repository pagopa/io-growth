@startuml Upload Image Sequence Diagram

actor "FE (User App)" as FE
participant "BFF (Our System)" as BFF
database "Local DB\n(partitionKey, idLavorazione, state)" as DB
box "INPS Services (PDND)" #LightBlue
  participant "MS INPS\n(GestioneDomandaCED)" as INPS
end box

title 3. Photo Submission (FornisciFoto) - UPLOADING_PHOTO state

FE -> BFF: Submit Photo (idLavorazione, fotoCED)

BFF -> DB: Retrieve Record R (idLavorazione, IK_CURRENT)
DB --> BFF: R

== Local DB Write 1: Intermediate state ==
BFF -> DB: UPDATE Record R (state: UPLOADING_PHOTO)

alt DB Write 1 SUCCESS
    DB --> BFF: OK

    BFF -> INPS: FornisciFoto(idLavorazione, fotoCED) \n <<Header: Idempotency Key = R.IK_CURRENT>>

    alt INPS Success (HTTP 200 OK)
        INPS --> BFF: idLavorazione (X)

        == Local DB Write 2: Update to READY_FOR_DOCUMENTS_UPLOAD ==
        BFF -> DB: UPDATE Record R (state: READY_FOR_DOCUMENTS_UPLOAD)

        alt DB Update SUCCESS
            DB --> BFF: OK
            BFF --> FE: Success (Next step: Confirmation required)

        else DB Update FAILURE (***INCONSISTENCY POINT***)
            DB --> BFF: ERROR (Timeout)
            note right of BFF: INPS has confirmed photo (esitoCheck=30). \nLocal DB shows UPLOADING_PHOTO. \nReconciliation (Flow 1) will fix this disparity.
            BFF --> FE: System Error (HTTP 500)
        end

    else INPS Failure (HTTP 400 BAD REQUEST)
        INPS --> BFF: Error Code (e.g., 903: FOTO NON CONFORME)
        BFF --> FE: Validation Error: Photo must be re-submitted (Details: Error Code)
    end

else DB Write 1 FAILURE (Fatal Error)
    DB --> BFF: ERROR (e.g., Connection issue)
    BFF --> FE: HTTP 503 Service Unavailable
end
@enduml
