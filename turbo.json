{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [],
      "outputs": []
    },
    "typecheck": {
      "inputs": [
        "src/**/*.ts",
        "package.json",
        "tsconfig.json",
        "!vitest.config.*"
      ],
      "outputs": [],
      "dependsOn": ["^build", "^typecheck"]
    },
    "lint": {
      "inputs": ["src/**/*.ts"]
    },
    "lint:check": {
      "inputs": ["src/**/*.ts"]
    },
    "format:check": {},
    "test": {
      "dependsOn": ["^build"],
      "inputs": [],
      "outputLogs": "errors-only"
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": [],
      "outputs": ["coverage"],
      "outputLogs": "errors-only"
    }
  }
}
